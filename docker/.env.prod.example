# Production Environment Configuration
# Copy this to .env.prod and fill in your values
# Usage: docker-compose --env-file .env.prod -f docker-compose.prod.yaml up -d

# Database (REQUIRED - replace with your managed database URL)
ERREIA_DATABASE_URL=postgres://user:password@postgres.example.com:5432/erreia?sslmode=require

# Storage - MinIO or S3 (REQUIRED)
ERREIA_STORAGE_ACCESS_KEY=your-access-key-here
ERREIA_STORAGE_SECRET_KEY=your-secret-key-here
ERREIA_STORAGE_PUBLIC_ENDPOINT=https://objects.example.com
ERREIA_STORAGE_USE_SSL=true
ERREIA_STORAGE_BUCKET=erreia
ERREIA_STORAGE_REGION=us-east-1

# Session Security (REQUIRED behind TLS proxy)
ERREIA_SESSION_COOKIE_SECURE=true
ERREIA_SESSION_LIFETIME=720h

# Server (REQUIRED)
ERREIA_BASE_URL=https://example.com

# MinIO Container Credentials (for docker-compose only; use strong credentials)
POSTGRES_USER=erreia
POSTGRES_PASSWORD=generate-strong-password-here
POSTGRES_DB=erreia

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=generate-strong-password-here
MINIO_BUCKET=erreia

# GitHub Container Registry Image
GHCR_IMAGE=ghcr.io/felipedsvit/erreia:v1.0.0
