# Server
ERREIA_HTTP_ADDR=:8080
ERREIA_BASE_URL=http://localhost:8080

# Database
ERREIA_DATABASE_URL=postgres://erreia:erreia@postgres:5432/erreia?sslmode=disable

# Sessions
ERREIA_SESSION_LIFETIME=720h
ERREIA_SESSION_COOKIE_NAME=erreia_session
ERREIA_SESSION_SECURE=false

# MinIO / S3 (both ACCESS_KEY and SECRET_KEY are required)
ERREIA_STORAGE_ENDPOINT=minio:9000
ERREIA_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
ERREIA_STORAGE_ACCESS_KEY=minioadmin
ERREIA_STORAGE_SECRET_KEY=minioadmin
ERREIA_STORAGE_BUCKET=erreia
ERREIA_STORAGE_REGION=us-east-1
ERREIA_STORAGE_PRESIGN_TTL=15m
ERREIA_STORAGE_USE_SSL=false

# Realtime
ERREIA_REALTIME_CHANNEL=erreia_board_events

# App
ERREIA_ENV=dev
