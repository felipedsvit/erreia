package templates

templ Home(authed bool) {
	@Layout("Home") {
		<main class="page-center page-wide">
			<h1 class="h1">erreia</h1>
			<p class="mt-3 muted">a tiny Kanban that lives in your browser tab.</p>
			<div class="mt-10 row gap-3">
				if authed {
					<a href="/dashboard" class="btn btn-primary">Open dashboard</a>
				} else {
					<a href="/login" class="btn btn-primary">Sign in</a>
					<a href="/register" class="btn btn-secondary">Create account</a>
				}
			</div>
		</main>
	}
}
